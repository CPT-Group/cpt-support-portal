  "facts": {
    "syntax_fundamentals": {
      "css_rule": {
        "statement": "CSS rules consist of a selector and a declaration block containing property-value pairs",
        "confidence": 1.0,
        "source": "W3C CSS Syntax Module Level 3",
        "example": "selector { property: value; property2: value2; }",
        "structure": {
          "selector": "Targets HTML elements",
          "declaration_block": "Enclosed in curly braces { }",
          "declaration": "property: value pair separated by colon",
          "separator": "Declarations separated by semicolons"
        }
      },
      "comments": {
        "statement": "CSS comments use /* */ syntax and can span multiple lines",
        "confidence": 1.0,
        "source": "W3C CSS Syntax Module Level 3",
        "example": "/* This is a comment */",
        "multiline": "/* This is\n   a multi-line\n   comment */"
      },
      "at_rules": {
        "statement": "CSS at-rules start with @ and provide special instructions",
        "confidence": 1.0,
        "source": "W3C CSS Syntax Module Level 3",
        "examples": [
          "@import 'styles.css'; - Import external stylesheet",
