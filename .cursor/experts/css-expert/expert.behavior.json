    "selectors": {
      "type_selector": {
        "statement": "Type selectors target elements by tag name",
        "confidence": 1.0,
        "source": "MDN CSS Selectors Reference",
        "example": "p { color: blue; } - Targets all <p> elements",
        "specificity": "0,0,1"
      },
      "class_selector": {
        "statement": "Class selectors use dot (.) prefix to target elements with specified class attribute",
        "confidence": 1.0,
        "source": "MDN CSS Selectors Reference",
        "example": ".button { background: red; } - Targets class=\"button\"",
        "specificity": "0,1,0",
        "html_usage": "<div class=\"button\">Click</div>"
      },
      "id_selector": {
        "statement": "ID selectors use hash (#) prefix to target element with specified id attribute",
        "confidence": 1.0,
        "source": "MDN CSS Selectors Reference",
        "example": "#header { height: 100px; } - Targets id=\"header\"",
        "specificity": "1,0,0",
        "uniqueness": "IDs should be unique per page"
      },
      "universal_selector": {
        "statement": "Universal selector (*) targets all elements",
        "confidence": 1.0,
        "source": "MDN CSS Selectors Reference",
        "example": "* { margin: 0; padding: 0; }",
        "specificity": "0,0,0",
        "use_case": "CSS resets"
      },
      "attribute_selector": {
        "statement": "Attribute selectors target elements based on attributes and values",
        "confidence": 1.0,
        "source": "MDN CSS Selectors Reference",
        "patterns": [
          "[attr] - Has attribute",
          "[attr=value] - Exact match",
          "[attr~=value] - Contains word",
          "[attr|=value] - Starts with value or value-",
          "[attr^=value] - Starts with value",
          "[attr$=value] - Ends with value",
          "[attr*=value] - Contains substring"
        ],
        "example": "input[type=\"text\"] { border: 1px solid gray; }"
      },
      "pseudo_class": {
        "statement": "Pseudo-classes target elements in specific states using colon (:) syntax",
        "confidence": 1.0,
        "source": "MDN CSS Selectors Reference",
        "common_pseudo_classes": [
          ":hover - Mouse over",
          ":active - Being activated (clicked)",
          ":focus - Has keyboard focus",
          ":visited - Visited link",
          ":first-child - First child of parent",
          ":last-child - Last child of parent",
          ":nth-child(n) - Nth child",
          ":nth-of-type(n) - Nth element of type",
          ":not(selector) - Does not match selector",
          ":checked - Checked input",
          ":disabled - Disabled input"
        ],
        "example": "button:hover { background: blue; }"
      },
      "pseudo_element": {
        "statement": "Pseudo-elements target specific parts of elements using double colon (::) syntax",
        "confidence": 1.0,
        "source": "MDN CSS Selectors Reference",
        "pseudo_elements": [
          "::before - Insert content before element",
          "::after - Insert content after element",
          "::first-line - First line of text",
          "::first-letter - First letter",
          "::selection - Selected text",
          "::placeholder - Input placeholder text"
        ],
        "example": "p::first-letter { font-size: 2em; }",
        "content_required": "::before and ::after require content property"
      },
      "combinator": {
        "statement": "Combinators define relationships between selectors",
        "confidence": 1.0,
        "source": "MDN CSS Selectors Reference",
        "combinators": [
          {
            "symbol": "space",
            "name": "Descendant combinator",
            "description": "Matches descendants at any level",
            "example": "div p { } - All <p> inside <div>"
          },
          {
            "symbol": ">",
            "name": "Child combinator",
            "description": "Matches direct children only",
            "example": "ul > li { } - Direct <li> children of <ul>"
          },
          {
            "symbol": "+",
            "name": "Adjacent sibling combinator",
            "description": "Matches immediately following sibling",
            "example": "h1 + p { } - <p> immediately after <h1>"
          },
          {
            "symbol": "~",
            "name": "General sibling combinator",
            "description": "Matches all following siblings",
            "example": "h1 ~ p { } - All <p> siblings after <h1>"
          }
        ]
      }
    },

    "cascade_and_specificity": {
      "cascade": {
        "statement": "Cascade determines which rules apply when multiple rules target same element",
        "confidence": 1.0,
        "source": "MDN Cascade and inheritance",
        "order_of_precedence": [
          "1. Importance (!important)",
          "2. Specificity (ID > Class > Type)",
          "3. Source order (later rules override earlier)"
        ],
        "important": "!important overrides normal declarations but should be avoided"
      },
      "specificity": {
        "statement": "Specificity is calculated as (inline, ID, class/attribute/pseudo-class, type/pseudo-element)",
        "confidence": 1.0,
        "source": "MDN Cascade and inheritance",
        "calculation": [
          "Inline styles: 1,0,0,0 (highest)",
          "IDs: 0,1,0,0",
          "Classes, attributes, pseudo-classes: 0,0,1,0",
          "Types, pseudo-elements: 0,0,0,1",
          "Universal selector (*): 0,0,0,0"
        ],
        "examples": [
          "#nav .link { } = 0,1,1,0",
          "ul li a { } = 0,0,0,3",
          ".btn:hover { } = 0,0,2,0"
