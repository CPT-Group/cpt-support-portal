# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Salesforce OAuth token storage (dev)
.sf_tokens.json

# Script temp outputs
scripts/describe-out.json
scripts/verify-createable-fields.txt

# Salesforce JWT key/cert (do not commit)
scripts/salesforce-jwt/server.key
scripts/salesforce-jwt/server.crt

# screenshots (captured for Confluence, not tracked in git)
/screenshots

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
